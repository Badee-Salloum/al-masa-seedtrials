# Copy to .env and fill in. NEVER commit .env (gitignored).
# Neon: DATABASE_URL = POOLED host (-pooler, pgbouncer) for the serverless app;
#       DIRECT_URL   = DIRECT host (no -pooler) for prisma migrate.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require"

# Auth.js — generate with: npx auth secret  (or openssl rand -base64 33)
AUTH_SECRET="CHANGE_ME"
AUTH_URL="http://localhost:3000"

# Vercel Blob (attachments) — from the Vercel dashboard / `vercel blob` (optional in local dev)
BLOB_READ_WRITE_TOKEN=""

# Set to "false" to relax mandatory 2FA for managers/owners (e.g. testing)
REQUIRE_2FA="true"
